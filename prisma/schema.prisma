// TradeJourney - Prisma schema
// Postgres (Supabase / Neon). Run: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // for migrations via Supabase pooler
}

enum TradeSide {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum TradeOutcome {
  TP
  SL
  SP
}

model User {
  id        String   @id @default(cuid())
  // Supabase auth.users.id (UUID). Set when integrating Supabase Auth.
  authId    String?  @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts        Account[]
  journalEntries  JournalEntry[]
}

model Account {
  id             String   @id @default(cuid())
  userId         String
  name           String
  broker         String?
  currency       String   @default("USD")
  initialBalance Decimal  @db.Decimal(18, 2) @default(0)
  createdAt      DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId])
}

model Trade {
  id        String       @id @default(cuid())
  accountId String?
  userId    String?      // Supabase auth.users.id

  symbol  String
  side    TradeSide
  status  TradeStatus  @default(CLOSED)
  outcome TradeOutcome?

  // Sizing
  leverage Decimal @db.Decimal(8, 2)  @default(1)
  size     Decimal @db.Decimal(18, 5) // margin size

  // Prices
  entry Decimal  @db.Decimal(18, 5)
  exit  Decimal? @db.Decimal(18, 5)

  // Results
  pnl       Decimal? @db.Decimal(18, 2) // P&L in $
  rMultiple Decimal? @db.Decimal(8, 2)
  fees      Decimal  @db.Decimal(18, 2) @default(0)
  holdingDuration String?

  // Strategy
  chartUrl    String?  @map("chart_url")
  plan        String?
  notes       String?
  strategy    String?
  screenshots String[] @default([])
  tags        String[] @default([])

  entryAt   DateTime @default(now())
  exitAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([userId])
  @@index([entryAt])
  @@index([outcome])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  mood      Int?     // 1-5
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
